{
  "name": "pi-packages",
  "version": "2.1.0",
  "private": true,
  "description": "Extensions for pi, the AI coding agent",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "npm run lint && npm run typecheck",
    "check:ci": "biome ci . && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "ci:detect": "./scripts/detect-ci-packages.sh"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "pi",
    "pi-package",
    "pi-packages",
    "pi-extensions",
    "pi-coding-agent",
    "extensions",
    "ai"
  ],
  "pi": {
    "extensions": [
      "./packages/pi-code-reasoning/extensions/index.ts",
      "./packages/pi-devtools/extensions/index.ts",
      "./packages/pi-exa/extensions/index.ts",
      "./packages/pi-notion/extensions/index.ts",
      "./packages/pi-ref-tools/extensions/index.ts",
      "./packages/pi-sequential-thinking/extensions/index.ts",
      "./packages/pi-specdocs/extensions/index.ts",
      "./packages/pi-statusline/extensions/index.ts"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@sinclair/typebox": "^0.34.0",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
