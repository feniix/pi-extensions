{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"files": {
		"includes": [
			"packages/*/extensions/**/*.ts",
			"packages/*/__tests__/**/*.ts",
			"packages/*/src/**/*.ts",
			"vitest.config.ts"
		]
	},
	"overrides": [
		{
			"includes": ["packages/pi-conductor/extensions/**/*.ts"],
			"linter": {
				"rules": {
					"complexity": {
						"noExcessiveCognitiveComplexity": {
							"level": "warn",
							"options": {
								"maxAllowedComplexity": 15
							}
						}
					}
				}
			}
		}
	]
}
